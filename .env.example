# LiveKit (cloud or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM via NVIDIA NIM (OpenAI-compatible)
# Reused from /Users/rachit/Documents/ideas/agent-ai/agent.py
NVIDIA_API_KEY=nvapi-REPLACE_ME
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=moonshotai/kimi-k2.6
# Smoke-tested 2026-05-07 against function calling probe:
#   moonshotai/kimi-k2.6           0.70s  tool_call ✓  (fastest)
#   nvidia/nemotron-3-nano-30b-a3b 2.13s  tool_call ✓  (NVIDIA Voice Agent backup)
#   moonshotai/kimi-k2-instruct    2.70s  tool_call ✓
#   z-ai/glm4.7                   25.67s  tool_call ✓  (too slow for voice)
#   z-ai/glm-5.1                  43.23s  tool_call ✓  (too slow for voice)
#   nvidia/nvidia-nemotron-nano-9b-v2  4.76s  no tool call
#   deepseek-ai/deepseek-v4-flash      timeout

# STT
DEEPGRAM_API_KEY=

# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Calendar
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
