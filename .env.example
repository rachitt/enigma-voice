# LiveKit (cloud or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM via NVIDIA NIM (OpenAI-compatible)
# Reused from /Users/rachit/Documents/ideas/agent-ai/agent.py
NVIDIA_API_KEY=nvapi-REPLACE_ME
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# config.py reads these (set them to the same values as the NVIDIA_* pair above):
LLM_API_KEY=nvapi-REPLACE_ME
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=moonshotai/kimi-k2.6
# Smoke-tested 2026-05-07 against function calling probe:
#   moonshotai/kimi-k2.6           0.70s  tool_call ✓  (fastest)
#   nvidia/nemotron-3-nano-30b-a3b 2.13s  tool_call ✓  (NVIDIA Voice Agent backup)
#   moonshotai/kimi-k2-instruct    2.70s  tool_call ✓
#   z-ai/glm4.7                   25.67s  tool_call ✓  (too slow for voice)
#   z-ai/glm-5.1                  43.23s  tool_call ✓  (too slow for voice)
#   nvidia/nvidia-nemotron-nano-9b-v2  4.76s  no tool call
#   deepseek-ai/deepseek-v4-flash      timeout

# STT
DEEPGRAM_API_KEY=

# TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Calendar
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_BASE_URL=https://api.cal.com/v2

# Telnyx (for SIP trunk; fill after signup — see docs/telnyx-setup.md)
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=
TELNYX_SIP_CONNECTION_ID=
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=
TELNYX_OUTBOUND_VOICE_PROFILE_ID=

# SIP trunk ids (LiveKit SIP)
SIP_OUTBOUND_TRUNK_ID=
SIP_INBOUND_TRUNK_ID=

# Outbound API auth (FastAPI server)
OUTBOUND_API_KEY=change-me-local-only

# Transfer-to-human destination (E.164 or sip: URI). Used by tools/transfer.py.
TRANSFER_DESTINATION=

# Telnyx Messaging Profile (for booking SMS via tools/sms.py)
TELNYX_MESSAGING_PROFILE_ID=
BOOKING_LINK=

# Dashboard server-side base URL for the FastAPI server
ENIGMA_API_URL=http://localhost:8000
